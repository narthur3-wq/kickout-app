{
  "name": "ko-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --ignore-pattern coverage --ignore-pattern dev-dist",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:match-sim": "playwright test tests/e2e/match-summary.spec.js",
    "test:smoke": "playwright test tests/e2e/supabase-smoke.spec.js",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "check": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "check:full": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "jsdom": "^29.0.1",
    "svelte": "^5.38.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "html2canvas": "^1.4.1"
  }
}
