# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_ADMIN_EMAILS=admin@example.com

# Supabase Edge Function secret (set in Supabase, not in Vercel):
# ALLOWED_ORIGIN=https://your-app-domain.vercel.app

# Optional smoke-test credentials for `npm run test:smoke`
# The smoke email must already be onboarded into `allowed_users` and have a Supabase Auth password.
# PAIRC_SMOKE_EMAIL=smoke@example.com
# PAIRC_SMOKE_PASSWORD=use-a-dedicated-test-account
# PAIRC_SMOKE_TEAM=Smoke Team
# PAIRC_SMOKE_OPPONENT=Smoke Opponent
# PAIRC_SMOKE_DATE=2026-03-30
